  "missions": [
    {
      "id": "scavenge",
      "title": "Scavenge",
      "description": "Send {mark}[bot]{/} to search local dump for parts or other useful things. Requires some knowledge of {mark}mechanics{/} or {mark}electronics{/}. With high enough {mark}combat{/} it is mostly safe.",
      "launch_text": "You explain to {mark}[bot]{/} what you expect from [bot.himher] and you give [bot.himher] an electronic tool to hack one of the entry doors into the dump along with a large bag to carry home whatever [bot.heshe] finds.\n\nOnce [bot.heshe] understands everything you send [bot.himher] to the dump site.\n\nWith some luck {mark}[bot]{/} should be back in a few hours with some goodies.",
      "available": "mc.mechanics>='E' and mc.electronics>='E'",
      "requirements": [
        ("bot.bot_mechanics>='D' or bot.bot_electronics>='D'","{mark}Mechanics{/} and/or {mark}Electronics{/} at {mark}D+{/}"),
        ("bot.autonomy>='D'","{mark}Autonomy{/} at {mark}D+{/}"),
      ],

      "duration": (1,2),
      "costs": [],
