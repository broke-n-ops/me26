  "dscs_role_tags": [
    {
      "id": "bedroom_toy",
      "description": "{good}This is what sexbots are for!{/}\nHave one or more join you in bed at night! Will improve your mood during sleep. Used skill: Sex.",
      "list_priority": 1,
    },
    {
      "id": "clerk",
      "description": "Will handle simple transactions in the shop giving you more time to work on bots. Will increase money, xp, and event chance when working. Used skill: Social.",
      "list_priority": 3,
    },
    {
      "id": "techie",
      "description": "Will help you fix defects and repair parts in the shop except when you're fixing [bot.himher]. Used skills: Mechanics, Electronics.",
      "list_priority": 4,
    },
    {
      "id": "shopkeeper",
      "description": "Will sell parts when you have other things to do. Will increase money. Used skills: Mechanics, Electronics, Social.\n\n{good}Shopkeepers are multitasking: Salesperson, Clerk, and Techie{/}.",
      "list_priority": 7,
    },
    {
      "id": "housekeeper",
      "description": "Does all those time consuming and boring things you don't like to do! Will clean and maintain your home and shop giving you more time to do other things (increases AP each turn). Used skill: Social.",
      "list_priority": 2,
    },
    {
      "id": "master_techie",
      "description": "\n{good}Important! Master Techies must have at least 90% chassis integrity and have a stable psychocore to perform their role.{/}\nWill repair damage and fix defects on other bots by themselves. You'll have more time to do other things! Used skills: Mechanics, Electronics.",
      "list_priority": 6,
    },
    {
      "id": "mission_manager",
      "description": "\n{good}Important! 1) Bot Managers must have 90% chassis integrity and have a stable psychocore to perform their role. 2) Bot Managers will not send other bots on missions unless their 'Manage' setting is 'On'{/}.\nBot Managers send other bots on missions based upon their priority setting: {mark}Highest Skill (default), Whore/Gigolo, Scavenge, or UFC Fight{/}. Used skill: Social.",
      "list_priority": 8,
    },
    {
      "id": "senior_techie",
      "description": "\n{good}Important! Senior Techies must have at least 90% chassis integrity and have a stable psychocore to perform their role.{/}\nWill fix defects and repair parts in inventory independently. You'll have more time to do other things! Used skills: Mechanics, Electronics.",
      "list_priority": 5,
    },
    {
      "id": "bot_trainer",
	  "description": "\n{good}Important! 1) Bot Trainers must have a trainer skill subject selected, at least 90% chassis integrity, and have a stable psychocore to perform their role. 2) The trainer and trainee must have the same skill subject.{/}\nWill train other bots in a specific skill if they have greater skill than the trainee bot. You'll have more time to do other things! Used skills: Specific Skill, Social.",
      "list_priority": 9,
    },
  ],

